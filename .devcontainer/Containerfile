# Dev Container image for paint-type
# Base: Chainguard Wolfi (minimal, supply-chain-secure)
# Build: podman build -t paint-type-dev -f .devcontainer/Containerfile .
#
# NOTE: This is the DEVELOPMENT container (VS Code, Codespaces, Gitpod).
#       For production builds, see the root Containerfile.
#       Both use the same base image version for consistency.

FROM cgr.dev/chainguard/wolfi-base:20240513@sha256:abc123def456...

# Install common development tools
RUN apk update && apk add --no-cache \
    bash \
    curl \
    git \
    openssh-client \
    ca-certificates \
    build-base \
    posix-libc-utils \
    shadow \
    && rm -rf /var/cache/apk/*

# Create non-root dev user (matches devcontainer.json remoteUser)
RUN groupadd -g 1000 nonroot || true \
    && useradd -m -u 1000 -g 1000 -s /bin/bash nonroot || true

# Set workspace directory
WORKDIR /workspaces/paint-type

# Default shell
ENV SHELL=/bin/bash

USER nonroot
